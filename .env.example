# ── Didit (Business Console -> API & Webhooks) ─────────────────────────
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
# secret_shared_key shown once when you create the webhook destination
DIDIT_WEBHOOK_SECRET=

# ── App ────────────────────────────────────────────────────────────────
# Public URL of this app once deployed (used for the post-verification redirect)
BASE_URL=https://your-app.onrender.com
PORT=3000
# Where the SQLite file lives (default: ./data.db; use /data/data.db in Docker/Render)
# DB_PATH=

# Shared secret to view /status?key=... — min 16 chars, use a long random string:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
STATUS_KEY=

# Max verification-session creations per IP per 15 minutes (default 10)
# SESSION_RATE_LIMIT=10

# ── Telegram notifications (optional but recommended) ──────────────────
# Message @BotFather to create a bot and get the token; message your bot
# once, then read chat.id from https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
