# Non-secret runtime settings for the deployed function.
# Copy to functions/.env — it is uploaded on deploy but never committed.
# Secrets (DIDIT_API_KEY, DIDIT_WEBHOOK_SECRET, STATUS_KEY) are NOT set here;
# the Firebase CLI prompts for them on first deploy and stores them in
# Google Secret Manager.

# Workflow UUID from the Didit Business Console
DIDIT_WORKFLOW_ID=

# Public URL of the deployed site, e.g. https://your-project.web.app
# (leave empty for the first deploy, fill in after)
BASE_URL=

# Telegram notifications (optional) — see README
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
